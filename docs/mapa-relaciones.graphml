<?xml version="1.0" encoding="UTF-8"?>
<!-- Mapa del cerebro claude-brain — RELACIONES / jerarquía (sin flujos: ver mapa-flujos.graphml).
     Documento de REFERENCIA: descripciones COMPLETAS (aclara cualquier duda). Lenguaje visual del
     README/widget: grafito + terracota (#D97757), emoji por elemento, borde por categoría
     (rojo=Forzoso, ámbar=Automático, verde=Norma, azul=Skill, gris=lib). Cajas anchas (400) + CADA
     descripción envuelta a mano (yEd NO envuelve solo) para que NADA se corte.
     Abrir en yEd -> Layout > Hierarchical (Top-to-Bottom). -->
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:y="http://www.yworks.com/xml/graphml"
         xmlns:yed="http://www.yworks.com/xml/yed/3"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://www.yworks.com/xml/schema/graphml/1.1/ygraphml.xsd">
  <key id="d0" for="node" yfiles.type="nodegraphics"/>
  <key id="d1" for="edge" yfiles.type="edgegraphics"/>
  <graph id="rel" edgedefault="directed">

    <node id="TIT"><data key="d0"><y:ShapeNode><y:Geometry height="140" width="400"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.0"/><y:NodeLabel alignment="left" textColor="#F2EDE6">🧠 claude-brain — mapa de RELACIONES&#10;&#10;📜 NORMA (verde) ← la hace cumplir…&#10;🔒 hook FORZOSO (rojo, bloquea) / 🔔 NUDGE (ámbar, avisa)&#10;💡 SKILL (azul) usa los hooks · ⚙ lib (gris)&#10;— flecha: enforce / usa / source&#10;- - punteada terracota: 🛡 P0 protege la integridad</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== NORMAS (verde) — descripción completa ===== -->
    <node id="N_DOD"><data key="d0"><y:ShapeNode><y:Geometry height="66" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🎯 Definición de LISTO&#10;verde técnico ≠ LISTO: build+tests+memoria es&#10;necesario pero NO suficiente; falta (1) QA del&#10;usuario o (2) su OK expreso de cierre</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_DOC"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🪞 doc = realidad&#10;al cambiar algo, su doc se actualiza en la MISMA&#10;tanda (README / memoria / dashboard / comentarios)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_GIT"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌿 Flujo de git&#10;ramita → MR → develop (con squash); main es&#10;release-only; NUNCA push directo a develop/main</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_MINI"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌱 Modelo MINI-DEVELOP&#10;ramitas → rama personal/integración por merge&#10;LOCAL (sin fricción); solo el MR a develop se gatea</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_COST"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">💰 Consentimiento de costo de delegación&#10;delegar cuesta por nivel: gratis (local) / incluido&#10;(ventana 5h) / metered (overage o API externa)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_ORQ"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🎼 Orquesta: delega y quédate en el loop&#10;con trabajo paralelizable: fan-out + supervisión&#10;(no grind serial); auto-reporte sin niñera</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_AISL"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🧱 Aislamiento de fan-out&#10;todo agente que MUTA/commitea corre en worktree&#10;AISLADO, nunca en el árbol de trabajo compartido</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_P0"><data key="d0"><y:ShapeNode><y:Geometry height="66" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#D97757" type="dashed" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🛡 P0 (PROPUESTA): Integridad de los guardarraíles&#10;Claude NO afloja sus propios candados de supervisión&#10;para desatorarse; cambiar un control exige tu OK&#10;EXPLÍCITO a cambiar ESE control (≠ el OK a la acción)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== HOOKS FORZOSOS (rojo) — descripción completa ===== -->
    <node id="H_BRANCH"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🚧 git-branch-guard  (PreToolUse / Bash)&#10;push o merge DIRECTO a develop·main → DENEGADO;&#10;te redirige al flujo ramita → MR</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SQUASH"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔗 merge-squash-guard  (PreToolUse / Bash)&#10;MR a develop sin --squash → DENEGADO (1 commit&#10;limpio por slice); main/release va SIN squash (EXENTO)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_CONF"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✋ confirmar-merge-develop  (Bash, repo compartido)&#10;integrar a develop/main sin tu OK EXPLÍCITO →&#10;DENEGADO (a main exige un OK súper explícito)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_DOD"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✅ dod-verificar  (Stop)&#10;declarar LISTO sin evidencia (1)/(2) → DENEGADO;&#10;afirmar QA visual sin ver la pantalla → DENEGADO</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SECRET"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🕵 secret-scan  (PreToolUse / Bash)&#10;commit/push con un secreto detectado → DENEGADO</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_LIMITE"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🛑 limite-gasto  (PreToolUse / Task)&#10;sin ventana 5h Y sin overage (AMBOS agotados) →&#10;FRENO duro a delegar (no hay capacidad)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_GATE"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">💸 delegacion-gate  (PreToolUse / Task)&#10;reclutar un agente con costo → pide tu&#10;consentimiento (ASK; 1×/compu ó 1×/workflow)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== HOOKS AUTOMÁTICOS / NUDGE (ámbar) — descripción completa ===== -->
    <node id="H_DASH"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📊 recordar-dashboard  (PreToolUse / Bash)&#10;en el push: recuerda actualizar el dashboard&#10;global + doc=realidad (README/docs) — cierre del slice</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_RAMA"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🕰 rama-vieja  (PreToolUse / Bash)&#10;avisa si la ramita arrastra una base vieja de develop</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_ARBOL"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌳 proteger-arbol  (PreToolUse / Bash)&#10;git destructivo (reset --hard / checkout -f / rebase)&#10;que orfanaría commits sin pushear → AVISA</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REG"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📝 delegacion-registrar  (PostToolUse / Task)&#10;materializa el "pregunta una sola vez"&#10;del gate de costo</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REP"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📮 delegacion-reporte  (PostToolUse / Task)&#10;al terminar un agente: recuerda registrar&#10;avance + limpiar su worktree</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SESION"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🧭 sesion-inicio  (SessionStart, repo-scoped)&#10;al abrir/retomar reinyecta rama + norma de&#10;git + orden de leer memoria</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_PRECOMP"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">💾 precompact-volcar-estado  (PreCompact, repo-scoped)&#10;antes de compactar el contexto, vuelca&#10;avance/decisiones/pendientes a memoria</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== LIBS / HELPERS (gris) ===== -->
    <node id="L_COMUN"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#232323"/><y:BorderStyle color="#8A8A8A" width="1.5"/><y:NodeLabel textColor="#CFC8C0">⚙ delegacion-comun  (lib)&#10;clasificación de costo compartida&#10;(gate y registrador no divergen)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="L_WT"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#232323"/><y:BorderStyle color="#8A8A8A" width="1.5"/><y:NodeLabel textColor="#CFC8C0">🧹 limpiar-worktrees.sh  (helper)&#10;barre worktrees zombies (rama mergeada);&#10;deja los vivos anotados en bitácora</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== SKILLS (azul) — descripción completa ===== -->
    <node id="S_CERRAR"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">📦 cerrar-slice  (skill, opt-in)&#10;ritual de cierre: evidencia (build+tests) + memoria/doc&#10;+ confirmar con el usuario + flujo de git + cosecha</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_FANOUT"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🧵 orquestar-fanout  (skill, opt-in)&#10;fan-out sin niñera: asigna ítems autocontenidos,&#10;worktrees aislados, auto-reporte y limpieza al cerrar</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_NET"><data key="d0"><y:ShapeNode><y:Geometry height="54" width="400"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔩 skills .NET (plantilla, específicas de stack)&#10;crear-pagina-blazor, migracion-ef,&#10;build-produccion, agregar-seed…</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== EDGES ===== -->
    <edge source="H_BRANCH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_SQUASH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">al integrar</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DOD" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">al declarar</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DASH" target="N_DOC"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">recuerda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_GATE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_LIMITE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_ARBOL" target="N_AISL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REP" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <edge source="N_P0" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#D97757">protege</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_BRANCH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <edge source="S_CERRAR" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_DASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_REP"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_GATE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <edge source="H_GATE" target="L_COMUN"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">source</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REG" target="L_COMUN"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">source</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REP" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">dispara</y:EdgeLabel></y:PolyLineEdge></data></edge>

  </graph>
</graphml>
