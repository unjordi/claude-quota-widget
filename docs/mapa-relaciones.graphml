<?xml version="1.0" encoding="UTF-8"?>
<!-- Mapa del cerebro claude-brain — RELACIONES / jerarquía (sin flujos de decisión: ver mapa-flujos.graphml).
     Lenguaje visual del README/widget: grafito + acento terracota (#D97757), emoji por elemento,
     borde por categoría (rojo=Forzoso, ámbar=Automático, verde=Norma, azul=Skill, gris=lib).
     Abrir en yEd -> Layout > Hierarchical (Top-to-Bottom). -->
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:y="http://www.yworks.com/xml/graphml"
         xmlns:yed="http://www.yworks.com/xml/yed/3"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://www.yworks.com/xml/schema/graphml/1.1/ygraphml.xsd">
  <key id="d0" for="node" yfiles.type="nodegraphics"/>
  <key id="d1" for="edge" yfiles.type="edgegraphics"/>
  <graph id="rel" edgedefault="directed">

    <!-- Título / leyenda (terracota) -->
    <node id="TIT"><data key="d0"><y:ShapeNode><y:Geometry height="120" width="340"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.0"/><y:NodeLabel alignment="left" textColor="#F2EDE6">🧠 claude-brain — mapa de RELACIONES&#10;&#10;📜 NORMA (verde) ← la hace cumplir…&#10;🔒 hook FORZOSO (rojo, bloquea) / 🔔 NUDGE (ámbar, avisa)&#10;💡 SKILL (azul) usa los hooks · ⚙ lib (gris)&#10;— flecha: enforce / usa / source · - - punteada: 🛡️ P0 protege</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== NORMAS (verde) ===== -->
    <node id="N_DOD"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🎯 Definición de LISTO&#10;(verde técnico ≠ LISTO)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_DOC"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🪞 doc = realidad</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_GIT"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌿 Flujo de git&#10;ramita→MR→develop; main release-only</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_MINI"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌱 Modelo MINI-DEVELOP</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_COST"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">💰 Costo de delegación</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_ORQ"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🎼 Orquesta (fan-out + loop)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_AISL"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="180"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🧱 Aislamiento de fan-out</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="N_P0"><data key="d0"><y:ShapeNode><y:Geometry height="52" width="200"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#D97757" type="dashed" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🛡️ P0 (PROPUESTA): Integridad&#10;de los guardarraíles</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== HOOKS FORZOSOS (rojo) ===== -->
    <node id="H_BRANCH"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🚧 git-branch-guard&#10;push/merge a develop·main → deny</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SQUASH"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔗 merge-squash-guard&#10;MR a develop sin --squash → deny</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_CONF"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✋ confirmar-merge-develop&#10;merge sin tu OK → deny (repo compartido)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_DOD"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✅ dod-verificar&#10;LISTO sin evidencia / QA visual a ciegas → deny</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SECRET"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🕵️ secret-scan&#10;commit/push con un secreto → deny</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_LIMITE"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🛑 limite-gasto&#10;sin ventana 5h Y sin overage → freno</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_GATE"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">💸 delegacion-gate&#10;delegar con costo → pide tu OK</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== HOOKS AUTOMÁTICOS / NUDGE (ámbar) ===== -->
    <node id="H_DASH"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📊 recordar-dashboard&#10;push → dashboard + doc=realidad</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_RAMA"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🕰️ rama-vieja&#10;avisa si la ramita arrastra base vieja</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_ARBOL"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌳 proteger-arbol&#10;git destructivo que orfanaría commits → avisa</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REG"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📝 delegacion-registrar&#10;materializa "pregunta una sola vez"</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REP"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📮 delegacion-reporte&#10;al terminar agente: registrar + limpiar</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SESION"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🧭 sesion-inicio&#10;reinyecta rama+norma+memoria</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_PRECOMP"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">💾 precompact-volcar-estado&#10;vuelca estado antes de compactar</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== LIBS / HELPERS (gris) ===== -->
    <node id="L_COMUN"><data key="d0"><y:ShapeNode><y:Geometry height="36" width="150"/><y:Fill color="#232323"/><y:BorderStyle color="#8A8A8A" width="1.5"/><y:NodeLabel textColor="#CFC8C0">⚙ delegacion-comun (lib)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="L_WT"><data key="d0"><y:ShapeNode><y:Geometry height="36" width="150"/><y:Fill color="#232323"/><y:BorderStyle color="#8A8A8A" width="1.5"/><y:NodeLabel textColor="#CFC8C0">🧹 limpiar-worktrees.sh</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== SKILLS (azul) ===== -->
    <node id="S_CERRAR"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="175"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">📦 cerrar-slice&#10;ritual de cierre</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_FANOUT"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="175"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🧵 orquestar-fanout&#10;fan-out sin niñera</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_NET"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="175"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔩 skills .NET (plantilla)&#10;blazor / ef / build / seed…</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== EDGES ===== -->
    <!-- enforce: hook -> norma (terracota tenue) -->
    <edge source="H_BRANCH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_SQUASH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce (integrar)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DOD" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce (declarar)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DASH" target="N_DOC"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">recuerda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_GATE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_LIMITE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_ARBOL" target="N_AISL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REP" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#B0A89F"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <!-- P0 protege guards (terracota punteada) -->
    <edge source="N_P0" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#D97757">protege</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_BRANCH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <!-- skill -> hook (azul: usa) -->
    <edge source="S_CERRAR" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_DASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_REP"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_GATE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#5B8DBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#5B8DBF">materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <!-- libs: source / dispara (gris) -->
    <edge source="H_GATE" target="L_COMUN"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">source</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REG" target="L_COMUN"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">source</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REP" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#8A8A8A"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#8A8078">dispara</y:EdgeLabel></y:PolyLineEdge></data></edge>

  </graph>
</graphml>
