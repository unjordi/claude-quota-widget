// Mapa del cerebro claude-brain — MAPA ÚNICO (fuente de verdad; el .graphml de yEd se genera de aquí).
// Contiene TODO: los flowcharts de decisión (⓪–⑧, fieles a la lógica real de cada hook leída del .sh)
// + las NORMAS que hacen cumplir (el cimiento) + la referencia de lib/skill de stack.
// diamante = decisión con ramas sí/no · caja = hook/paso · 🟢 pasa · 🔴 DENY · 🟠 ASK/AVISA · 📜 norma.
// Familias: instalación (⓪) · sesión (①) · git (②③④) · «terminado» (⑤⑥) · delegación (⑦⑧).
// El ancho del render de Graphviz NO importa: en yEd se acomoda POR FLUJO (no en una tira).
// Lenguaje visual del README/widget.  Render: dot -Tpng docs/mapa-flujos.dot -o docs/mapa-flujos.png
digraph flujos {
  rankdir=TB;
  bgcolor="#1B1712";
  compound=true;
  nodesep=0.35;
  ranksep=0.55;
  splines=true;
  node [shape=box style="rounded,filled" fillcolor="#2B2B2B" fontcolor="#F2EDE6"
        fontname="Helvetica" fontsize=12 margin="0.16,0.09" penwidth=2];
  edge [color="#D97757" fontcolor="#C9BFB4" fontname="Helvetica" fontsize=10 penwidth=1.3 arrowsize=0.8];

  LEG [shape=note fillcolor="#2B2622" color="#D97757" penwidth=2 fontcolor="#F2EDE6" fontname="Menlo" fontsize=11
       label="🧠  claude-brain — MAPA ÚNICO del cerebro\l(flowcharts fieles a cada hook + las normas que hacen cumplir)\l\l◆ diamante = decisión (ramas sí/no) · ▭ caja = hook / paso\l🟢  pasa/permite · 🔴  DENY/bloquea · 🟠  ASK/AVISA\l📜 NORMA (el cimiento) — cada flujo apunta a la norma que sirve\l\lBadge de tipo (arriba de cada nodo):\l  🔒 hook FORZOSO (bloquea · deny)  ·  🔔 hook AUTOMÁTICO (inyecta/recuerda, NO bloquea)\l  💡 skill  ·  ⚙ lib  ·  📜 norma  ·  🛡 P0\l\l────────────────────────────────────────────────────────\lÁrbol del cerebro (pestaña «Cerebro» del widget):\l\l🔒 Hooks Forzosos — bloquean (deny) · no negociables  (GLOBALES; los ★ ADEMÁS viajan por-repo, DEDUPLICADOS R1: la copia del repo cede si existe la global → 1×, no 2×)\l├─ ★🚧 git-branch-guard:  push/merge a develop·main → denegado\l├─ ★🔗 merge-squash-guard:  MR a develop CONFIRMADO sin --squash → denegado (SOLO develop · G4)\l├─ 🕵️ secret-scan:  commit/push con un secreto → denegado (incl. 1er push de rama nueva · G5)\l├─ ★✋ confirmar-merge-develop:  merge sin tu OK expreso → denegado (GLOBAL; gatea en repos con marca repo-compartido)\l├─ 💸 delegacion-gate:  delegar al 90% de tu ventana 5h → pide OK (fan-out: 1 ask por LOTE · G3)\l├─ 🛑 limite-gasto:  sin ventana 5h Y sin overage → freno duro (corre ANTES del gate · G6)\l└─ 📁 solo por-repo (viaja en el .claude del repo):\l   └─ ✅ dod-verificar:  cierre sin evidencia/OK → denegado; una pregunta NO salva un claim (G1); QA visual a ciegas también\l\l🔔 Automático — inyectan / recuerdan (no bloquean)\l├─ ★📊 recordar-dashboard:  en el push recuerda dashboard + doc=realidad (merge-base cae a origin/* en clon fresco · G8)\l├─ 🕰️ rama-vieja:  avisa si la ramita arrastra base vieja\l├─ 🌳 proteger-arbol:  git destructivo que orfanaría commits sin pushear → avisa (fan-out: worktree aislado)\l├─ 📝 delegacion-registrar:  materializa el «pregunta una sola vez»\l├─ 📮 delegacion-reporte:  al terminar un agente: registra avance + limpia su worktree\l├─ 🧵 rehidratar-hilo:  reinyecta hilo-mental-actual.md al abrir/retomar/compactar + GATE DE FRESCURA (GLOBAL)\l├─ 📈 aviso-contexto:  watermark — avisa «vuelca con checkpoint y compacta TÚ» antes del auto-compact (GLOBAL)\l└─ 📁 solo por-repo:\l   └─ 🧭 sesion-inicio:  reinyecta rama + norma + memoria al abrir/retomar/compactar\l\l📜 Normas — reglas que Claude se autoimpone (CLAUDE.md)\l├─ 🎯 Definition of Done:  verde técnico ≠ Done/Listo; exige QA o un OK explícito\l├─ 🪞 Doc = realidad:  cambió algo → su doc se actualiza en la tanda\l├─ 🌿 Flujo de git:  ramita → MR → develop; main es release-only\l└─ 💰 Costo de delegación:  gratis / incluido / con costo, según tu cuota\l\l💡 Skills — opt-in, las invocas tú\l├─ 📦 cerrar-slice:  build+tests+memoria al día + MR con resumen curado\l├─ 💾 checkpoint:  vuelca el HILO a memoria para compactar sin perderlo (proactivo)\l├─ 💧 rehidratar-hilo:  relee el HILO a mano (gemelo del hook; respaldo si un update del CLI rompe el auto-rehidratado)\l└─ 🧵 orquestar-fanout:  fan-out sin niñera: asigna del backlog, auto-reporta y limpia\l"];

  // ===================== ⓪ INSTALACIÓN / ACTUALIZACIÓN DEL CEREBRO =====================
  subgraph cluster_f8 {
    label="⓪ Instalación / actualización del cerebro   (install-brain · bootstrap-claude · aplicar-plantilla · [futuro] sincronizar-cerebro)";
    labeljust="l"; fontcolor="#5FA89E"; fontsize=14; color="#5FA89E"; style="rounded"; penwidth=1.6; margin=16;

    I8_IN [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="instalar o actualizar el cerebro\nen esta máquina / repo"];
    I8_AMBITO [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿ámbito?"];

    // --- GLOBAL (máquina) ---
    I8_GVEZ [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="GLOBAL (máquina):\n¿1ª vez o actualizar?"];
    I8_GINST [color="#7FB069" label="🟢  install-brain.sh (vía global directa en Mac/Windows)\ncopia los 13 hooks + skills a ~/.claude/, cablea settings.json,\ninstala normas (bloque BEGIN/END) + siembra dashboard (idempotente).\ninstall.sh lo envuelve SOLO en Linux/KDE (+ daemon+systemd+plasmoide;\nexige systemctl/kpackagetool6 → no corre en Mac/Windows)"];
    I8_GUPD [color="#E08E45" label="🟠  re-correr install-brain.sh\nidempotente Y ACTUALIZABLE: refresca hooks, re-cablea,\nREEMPLAZA el bloque de normas en su lugar\n(así se actualizó TIER 0)"];
    I8_GLIVE [color="#7FB069" label="🟢  cerebro GLOBAL vivo en la máquina\n(aplica a TODOS los repos)"];

    // --- POR-REPO (viaja por git) ---
    I8_RTIPO [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="POR-REPO:\n¿repo nuevo o existente?"];
    I8_CLON [color="#5FA89E" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="repo NUEVO desde la plantilla:\nel clon TRAE .claude/ (hooks+settings+skills+memoria)\npor git — el tooling VIAJA en el repo"];
    I8_APLICA [color="#E08E45" label="🟠  repo EXISTENTE: sembrar .claude/ es un paso MANUAL\n(NO scriptado). aplicar-plantilla-a-proyecto NO copia .claude/ —\nes un playbook de UI/arquitectura que ASUME el cerebro ya presente.\n🆕 hueco: no hay automatización para «sembrar el cerebro en un repo existente»"];
    I8_BOOT [color="#E08E45" label="🔔  bootstrap-claude.sh  (UNA vez tras clonar)\nsymlinkea la memoria + siembra dashboard + norma doc=realidad\n+ instala en ~/.claude un SUBCONJUNTO de globales + verifica jq\n(git se asume por el clone — NO lo verifica, pese a lo que dice el CLAUDE.md)"];
    I8_INV [color="#C0392B" label="🔴  DRIFT INVERSO (el peor): bootstrap hace cp -f INCONDICIONAL\n→ un clon con plantilla VIEJA PISA los 3 hooks globales con versiones\nstale. La dedup R1 es solo del CABLEADO (quién corre), NO del .sh\n(el binario siempre se sobreescribe) → un repo viejo CONTAMINA el global"];
    I8_WARN [shape=diamond fillcolor="#2B2622" color="#C0392B" penwidth=2 label="¿el subconjunto del bootstrap\n= lo que instala install-brain?"];
    I8_DIV [color="#C0392B" label="🔴  NO — DOS rutas de install con conjuntos DISTINTOS:\nbootstrap-claude instala 3 (git-branch · recordar-dashboard · squash);\ninstall-brain instala 13 → FALTAN secret-scan, watermark, rehidratar,\ndelegación, confirmar-merge, proteger-arbol, rama-vieja, limite-gasto\n(raíz de #4: clonar la plantilla y bootstrapear NO da secret-scan)\n🆕 reconciliar: lista ÚNICA de «qué es global»"];
    I8_RLIVE [color="#7FB069" label="🟢  cerebro del repo vivo\n(hooks del repo por git + los globales que sí se instalaron)"];

    // --- ACTUALIZACIÓN POR-REPO (el hueco) ---
    I8_RUPD [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="el brain EVOLUCIONÓ:\n¿cómo se actualizan los .claude/\nde un repo YA instalado?"];
    I8_HUECO [color="#C0392B" label="🔴  HUECO — NO hay mecanismo: las copias por-repo\nDRIFTEAN del brain (hallazgo #3). Hoy solo se «arregla»\nre-aplicando la plantilla a mano (nadie lo hace → envejecen)"];
    I8_FIX [color="#C9A227" label="🆕 propuesta: sincronizar-cerebro.sh (fuente única = brain, NO cp -f\nciego) + SELLO DE VERSIÓN del cerebro (hoy no existe; el widget sí) +\ncheck de DRIFT en test-brain/CI → el desfase (en AMBOS sentidos) se DETECTA.\nTambién: rama de desinstalación/rollback (uninstall-brain.sh) fuera de este dibujo\n📜 → 🧩 toda norma nace con su mecanismo"];

    I8_IN -> I8_AMBITO;
    I8_AMBITO -> I8_GVEZ  [label="global"];
    I8_AMBITO -> I8_RTIPO [label="por-repo"];
    I8_GVEZ -> I8_GINST [label="1ª vez"];
    I8_GVEZ -> I8_GUPD  [label="actualizar" color="#E08E45"];
    I8_GINST -> I8_GLIVE;
    I8_GUPD -> I8_GLIVE;
    I8_RTIPO -> I8_CLON   [label="nuevo"];
    I8_RTIPO -> I8_APLICA [label="existente"];
    I8_CLON -> I8_BOOT;
    I8_APLICA -> I8_BOOT;
    I8_BOOT -> I8_WARN;
    I8_BOOT -> I8_INV   [label="cp -f incondicional" color="#C0392B"];
    I8_INV -> I8_FIX    [label="lo resuelve 🆕" color="#C9A227" style=dashed];
    I8_WARN -> I8_DIV   [label="hoy: no" color="#C0392B"];
    I8_WARN -> I8_RLIVE [label="meta: sí" color="#7FB069"];
    I8_DIV -> I8_RLIVE;
    I8_RLIVE -> I8_RUPD [label="con el tiempo…" style=dashed];
    I8_RUPD -> I8_HUECO [label="hoy" color="#C0392B"];
    I8_HUECO -> I8_FIX  [label="propuesta 🆕" color="#C9A227" style=dashed];
  }

  // ===================== ① CICLO DE VIDA DE LA SESIÓN =====================
  subgraph cluster_f0 {
    label="① Ciclo de vida de la sesión   (bootstrap 1× · SessionStart: 🔔 rehidratar-hilo GLOBAL con gate de FRESCURA + 🔔 sesion-inicio por-repo · 💾 checkpoint vuelca el hilo · 🔔 aviso-contexto = watermark anti-auto-compact)";
    labeljust="l"; fontcolor="#5B8DBF"; fontsize=14; color="#5B8DBF"; style="rounded"; penwidth=1.6; margin=16;

    Z_OPEN [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="abres Claude Code en un folder"];
    Z_GIT  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿repo git CON .claude/\n(cerebro autocontenido)?"];
    Z_PLAIN [color="#7FB069" label="🟢  folder simple: sin hooks del repo;\naplican solo los hooks GLOBALES de la máquina\n(en repos personales → auto-mode genérico · P10)"];
    Z_BOOT [color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="🔧  bootstrap-claude.sh (UNA vez tras clonar)\ninstala hooks GLOBALES + enlaza el cerebro + verifica\ngit & jq; los hooks del repo se cablean en\n.claude/settings.json (viajan por git). Aquí vive el «protocolo»"];

    Z_START [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔔\n🧭  sesion-inicio  (SessionStart)\nsource: startup / resume / compact"];
    Z_INJECT [color="#E08E45" label="🟠  inyecta additionalContext: rama actual + NORMA de git\n+ ritual anti-hilo (lee MEMORY.md + AGENTS.md;\nNO declares LISTO sin evidencia)\n+ avisa si lo que ves es de otra rama (P16)\n📜 → 🌿 Flujo de git · 🎯 Def. de LISTO"];
    Z_PROT [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿rama = develop/main?"];
    Z_PROTW [color="#E08E45" label="🟠  + aviso: rama PROTEGIDA →\nsaca una ramita feat/… desde develop"];
    Z_EST [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿existe\nestado-proyecto.md?"];
    Z_ESTW [color="#E08E45" label="🟠  + inyecta su Resumen\n(dónde quedó el avance)"];
    Z_READY [color="#7FB069" label="🟢  contexto rehidratado → a trabajar\n(sin perder el hilo entre sesiones/compus)"];

    Z_AVISO [color="#E08E45" label="🔔\n📈  aviso-contexto  (PostToolUse · GLOBAL · watermark)\nmide el CRECIMIENTO del contexto desde el último /compact\n(proxy: líneas del transcript vs baseline; umbral tunable,\ndebounce por banda). Al cruzar el umbral INYECTA:\n«vuelca con checkpoint y compacta TÚ ahora» (con holgura)\n→ el auto-compact-sorpresa se vuelve fallback raro"];
    Z_CHECK [color="#E08E45" label="💾  checkpoint  (skill — TÚ lo invocas, PROACTIVO)\nvuelca el HILO → .claude/memory/hilo-mental-actual.md\nen pausas / ANTES de /compact\n📜 → 🪞 doc=realidad · 💡 cerrar-slice §2 hace este mismo volcado"];
    Z_REHID [color="#E08E45" label="🔔\n🧵  rehidratar-hilo  (SessionStart · GLOBAL)\nreinyecta hilo-mental-actual.md si existe → el HILO vuelve\n+ GATE DE FRESCURA: si mtime>12h o rama distinta →\ndegrada a «⚠️ posiblemente OBSOLETO» (no engaña)\n+ en source=compact RESETEA el baseline del watermark\n(silencioso si no existe hilo)"];

    Z_OPEN -> Z_GIT;
    Z_GIT -> Z_PLAIN [label="no" color="#7FB069"];
    Z_GIT -> Z_BOOT  [label="1ª vez tras clonar\n(bootstrap, UNA vez)" style=dashed color="#8A8A8A"];
    Z_GIT -> Z_START [label="sí (repo con cerebro)\n— CADA sesión" color="#5B8DBF"];
    Z_BOOT -> Z_START [style=dashed color="#8A8A8A"];
    Z_START -> Z_INJECT;
    Z_INJECT -> Z_PROT;
    Z_PROT -> Z_PROTW [label="sí" color="#E08E45"];
    Z_PROT -> Z_EST   [label="no"];
    Z_PROTW -> Z_EST;
    Z_EST -> Z_ESTW  [label="sí" color="#E08E45"];
    Z_EST -> Z_READY [label="no" color="#7FB069"];
    Z_ESTW -> Z_READY;
    Z_READY -> Z_AVISO [label="durante la corrida\n(vigila cada tool)" style=dashed];
    Z_AVISO -> Z_CHECK [label="cruza el umbral →\nvuelca + propón /compact" color="#E08E45"];
    Z_READY -> Z_CHECK [label="o TÚ en una pausa\n(proactivo)" style=dashed color="#8A8A8A" constraint=false];
    Z_CHECK -> Z_REHID [label="/compact o auto-compact →\nSessionStart source=compact\n(dispara sesion-inicio + rehidratar-hilo)" style=dashed color="#5B8DBF"];
    Z_REHID -> Z_READY [label="hilo restaurado →\nsigue sin perderlo" color="#7FB069" constraint=false];
    Z_START -> Z_REHID [label="misma SessionStart\n(startup/resume/compact · global + por-repo)" style=dotted color="#8A8A8A" constraint=false];
  }

  // ===================== ② INTEGRAR a develop/main =====================
  subgraph cluster_f1 {
    label="② Integrar rama a develop/main   (git-branch-guard → merge-squash-guard → confirmar-merge-develop)";
    labeljust="l"; fontcolor="#C0392B"; fontsize=14; color="#C0392B"; style="rounded"; penwidth=1.6; margin=16;

    G1_IN  [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="intento de integrar\n(git push · glab mr merge · gh pr merge)"];
    G1_D1  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n🚧  git-branch-guard\n¿push DIRECTO\na develop/main?"];
    G1_DENY1 [color="#C0392B" label="🔴  DENY — no push a develop/main\nhaz ramita → MR (a main solo\nrelease del humano en la web)"];
    G1_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n🔗  merge-squash-guard\n¿MR con destino = develop CONFIRMADO\nSIN --squash?\n(SOLO develop obliga squash · G4 · msg tool-aware gh/glab · P5)"];
    G1_DENY2 [color="#C0392B" label="🔴  DENY — SOLO a develop se SQUASHEA\n(1 commit limpio/slice); rehaz con --squash.\nmain (release) / ramas personales / destino\nINDETERMINADO → LIBRES (fail-safe: no fuerza squash)"];
    G1_D3  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n✋  confirmar-merge-develop\n¿repo COMPARTIDO y\nfalta OK expreso del usuario\npara ESTE cierre?\n(busca tu OK en tus últimos 10 mensajes, no en líneas crudas · P17)"];
    G1_DENY3 [color="#C0392B" label="🔴  DENY — exige OK EXPRESO.\n«sigue/avanza» NO cuenta; a main pide\nOK SÚPER explícito (release). Itera en\nrama de integración con merge LOCAL"];
    G1_OK  [color="#7FB069" label="🟢  MERGE — develop: con --squash\nmain: release SIN squash\n📜 → 🌿 Flujo de git"];

    G1_IN -> G1_D1;
    G1_D1 -> G1_DENY1 [label="sí" color="#C0392B"];
    G1_D1 -> G1_D2    [label="no"];
    G1_D2 -> G1_DENY2 [label="sí (develop confirmado)" color="#C0392B"];
    G1_D2 -> G1_D3    [label="no · main · personal · indeterminado"];
    G1_D3 -> G1_DENY3 [label="sí" color="#C0392B"];
    G1_D3 -> G1_OK    [label="no (hay OK)" color="#7FB069"];
  }

  // ===================== ③ COMANDO GIT EN BASH — dos guards PARALELOS e independientes ==========
  // secret-scan (🔒 bloquea) y proteger-arbol (🔔 avisa) son DOS PreToolUse/Bash separados que reciben
  // la MISMA entrada; NO hay despachador — cada hook filtra por su cuenta si el comando le incumbe.
  subgraph cluster_f2 {
    label="③ Comando git en Bash · guards que lo inspeccionan   (🔒 secret-scan bloquea · 🔔 proteger-arbol avisa)";
    labeljust="l"; fontcolor="#D97757"; fontsize=14; color="#D97757"; style="rounded"; penwidth=1.6; margin=16;

    GG_IN   [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="comando Bash con git (PreToolUse/Bash)\n→ los DOS hooks lo reciben en paralelo (sin despachador)"];

    // --- rama secret-scan (🔒 bloquea) — filtra POR SÍ MISMO si es commit/push ---
    S_IS  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n🕵  secret-scan\n¿es git commit / push?"];
    S_NA  [color="#7FB069" label="🟢  no incumbe → pasa"];
    S_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿escape deliberado?\n(--no-verify · CLAUDE_SKIP_SECRET_SCAN=1)"];
    S_PASA2 [color="#7FB069" label="🟢  pasa (el humano manda)"];
    S_D3  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿repo git y rango\ndeterminable?\n(commit: staging · push: @{u}..HEAD;\nsin upstream = 1er push de rama nueva →\ncae al merge-base con develop/main · G5)"];
    S_PASA3 [color="#7FB069" label="🟢  pasa (fail-open:\nsin git ni base determinable, no bloquea)"];
    S_D4  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿línea AGREGADA con patrón de\nSECRETO (AKIA · PEM · sk-ant · gh_ ·\nglpat · xox · AIza) NO placeholder?"];
    S_PASA4 [color="#7FB069" label="🟢  pasa (sin secretos)"];
    S_DENY [color="#C0392B" label="🔴  DENY — secreto detectado (redacta el match).\nSácalo a env/gestor/*.local; si ya estaba\ncommiteado ROTA la credencial; si es falso\npositivo, --no-verify o CLAUDE_SKIP_SECRET_SCAN=1"];

    // --- rama proteger-arbol (🔔 avisa) — filtra POR SÍ MISMO si es destructivo ---
    A_IS  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔔\n🌳  proteger-arbol\n¿es git DESTRUCTIVO?\n(reset --hard/--merge/--keep ·\ncheckout -f · rebase · branch -D)"];
    A_NA  [color="#7FB069" label="🟢  no incumbe → pasa"];
    A_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿orfanaría >0 commits\nSIN pushear? (@{u}..HEAD)"];
    A_PASA [color="#7FB069" label="🟢  pasa (sin ruido)"];
    A_WARN [color="#E08E45" label="🟠  AVISA (no bloquea) — puede orfanar\nN commits en el árbol PRINCIPAL o worktree.\nAgente de fan-out: usa worktree AISLADO;\nsi rebobinas a propósito, ignóralo\n📜 → 🧱 Aislamiento · 💡 → 🧵 orquestar-fanout"];

    GG_IN -> S_IS;   // los dos hooks reciben la MISMA entrada, en paralelo
    GG_IN -> A_IS;

    S_IS -> S_NA [label="no" color="#7FB069"];
    S_IS -> S_D2 [label="sí (commit/push)"];
    S_D2 -> S_PASA2 [label="sí" color="#7FB069"];
    S_D2 -> S_D3    [label="no"];
    S_D3 -> S_PASA3 [label="no" color="#7FB069"];
    S_D3 -> S_D4    [label="sí"];
    S_D4 -> S_PASA4 [label="no" color="#7FB069"];
    S_D4 -> S_DENY  [label="sí" color="#C0392B"];

    A_IS -> A_NA [label="no" color="#7FB069"];
    A_IS -> A_D2 [label="sí (destructivo)"];
    A_D2 -> A_PASA [label="no" color="#7FB069"];
    A_D2 -> A_WARN [label="sí" color="#E08E45"];
  }

  // ===================== ④ AL HACER PUSH — nudges (recordar-dashboard + rama-vieja) =====================
  subgraph cluster_f3 {
    label="④ Al hacer push · nudges   (🔔 recordar-dashboard: dashboard+doc · 🔔 rama-vieja: base vieja)";
    labeljust="l"; fontcolor="#E08E45"; fontsize=14; color="#E08E45"; style="rounded"; penwidth=1.6; margin=16;

    G6_IN  [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="comando Bash con git"];
    G6_PUSH [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿es git push\nde una ramita?"];
    G6_SIL [color="#7FB069" label="🟢  silencio\n(no es push de ramita)"];

    // --- rama recordar-dashboard ---
    G6_DASH [color="#E08E45" label="🔔\n📊  recordar-dashboard\nrecuerda: actualiza el Dashboard GLOBAL\n(append «>>» al final, no Edit)\n📜 → 🪞 doc=realidad · 💡 → 📦 cerrar-slice"];
    G6_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="doc=realidad: ¿algún commit\na pushear toca su doc?\n(README/.md/docs/memoria)"];
    G6_OK  [color="#7FB069" label="🟢  doc al día\n(sin recordatorio extra)"];
    G6_D3  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿AGREGA/QUITA\nun hook o skill?"];
    G6_HOOK [color="#E08E45" label="🟠  recuerda: actualiza el ÁRBOL del\ncerebro en README + el conteo de\nchecks de test-brain.sh"];
    G6_D4  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿toca código / features?"];
    G6_CODE [color="#E08E45" label="🟠  recuerda: actualiza la doc que lo\nDESCRIBE (README/memoria/comentarios)\nen esta misma tanda"];
    G6_NA  [color="#7FB069" label="🟢  nada que recordar"];

    // --- rama rama-vieja ---
    G6_RV  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔔\n🕰  rama-vieja\n¿la ramita está ≥40 commits\nDETRÁS de origin/develop?"];
    G6_RV_OK [color="#7FB069" label="🟢  base fresca (sin aviso)"];
    G6_RV_WARN [color="#E08E45" label="🟠  AVISA: base vieja → el MR traerá ruido.\nRebasa antes: git fetch origin &&\ngit rebase origin/develop (repush --force-with-lease)\n📜 → 🌿 Flujo de git"];

    G6_IN -> G6_PUSH;
    G6_PUSH -> G6_SIL  [label="no" color="#7FB069"];
    G6_PUSH -> G6_DASH [label="sí"];
    G6_PUSH -> G6_RV   [label="sí"];
    G6_DASH -> G6_D2;
    G6_D2 -> G6_OK   [label="sí" color="#7FB069"];
    G6_D2 -> G6_D3   [label="no"];
    G6_D3 -> G6_HOOK [label="sí" color="#E08E45"];
    G6_D3 -> G6_D4   [label="no"];
    G6_D4 -> G6_CODE [label="sí" color="#E08E45"];
    G6_D4 -> G6_NA   [label="no" color="#7FB069"];
    G6_RV -> G6_RV_OK   [label="no" color="#7FB069"];
    G6_RV -> G6_RV_WARN [label="sí" color="#E08E45"];
  }

  // ===================== ⑤ DECLARAR «LISTO» al fin de turno (dod-verificar · Stop) =====================
  subgraph cluster_f4 {
    label="⑤ Declarar «LISTO» al fin de turno   (dod-verificar · Stop)";
    labeljust="l"; fontcolor="#C0392B"; fontsize=14; color="#C0392B"; style="rounded"; penwidth=1.6; margin=16;

    G2_IN  [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="fin de turno (Stop)\nse mira el último mensaje del asistente"];
    G2_D0  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n✅  dod-verificar  (Stop)\n¿es ESTATUS / espera / pregunta\nSIN un cierre afirmado co-ubicado?\n(en preview · con tu OK · ¿…? · P1;\nG1: el claim se evalúa sobre el texto SIN\nlos tramos ¿…? → una pregunta NO salva\nun cierre afirmado en el mismo mensaje)"];
    G2_ESC [color="#7FB069" label="🟢  no dispara\n(no es un cierre)"];
    G2_D1  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿afirma QA VISUAL\n(mockup/Chrome/pantalla) SIN\ncorrer tool de navegador este turno, y sin (1)?\n(G2b: la tool se detecta por ESTRUCTURA del\ntranscript —tool_use chrome-MCP/computer—,\nNO por la palabra «screenshot» en prosa)"];
    G2_VIS [color="#C0392B" label="🔴  BLOCK — QA visual A CIEGAS.\nEstatus honesto: «verificado técnico,\nSIN QA visual»; lo mira el usuario"];
    G2_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿afirma CIERRE?\n(listo/terminado/funciona/\nquedó/cerrado/a la par)"];
    G2_D3  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿el turno tocó CÓDIGO?\n(archivo que no sea .md/.txt ni memoria;\nG2a: TAMBIÉN cuenta la edición por Bash\n—sed -i · patch · redirección › · tee—,\nno solo un «file_path» de Edit/Write)"];
    G2_D4  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿cita marca de (1) QA\nconfirmado por el usuario\no (2) OK expreso de cierre?"];
    G2_OK  [color="#7FB069" label="🟢  cierra\n(build/tests + memoria se RECUERDAN\ncomo peldaño, no como candado)\n📜 → 🎯 Definición de LISTO"];
    G2_DENY [color="#C0392B" label="🔴  BLOCK — verde técnico ≠ LISTO.\nSin (1) ni (2) no se declara LISTO.\nSi es MIGRACIÓN: la prueba es\nAUDITORÍA DE PARIDAD, no build+tests"];

    G2_IN -> G2_D0;
    G2_D0 -> G2_ESC [label="sí" color="#7FB069"];
    G2_D0 -> G2_D1  [label="no"];
    G2_D1 -> G2_VIS [label="sí" color="#C0392B"];
    G2_D1 -> G2_D2  [label="no"];
    G2_D2 -> G2_ESC [label="no" color="#7FB069"];
    G2_D2 -> G2_D3  [label="sí"];
    G2_D3 -> G2_ESC [label="no (docs)" color="#7FB069"];
    G2_D3 -> G2_D4  [label="sí"];
    G2_D4 -> G2_OK   [label="sí" color="#7FB069"];
    G2_D4 -> G2_DENY [label="no" color="#C0392B"];
  }

  // ===================== ⑥ CERRAR UN SLICE (ritual de 5 pasos · cerrar-slice) =====================
  subgraph cluster_f5 {
    label="⑥ Cerrar un slice · ritual de 5 pasos   (cerrar-slice · skill)";
    labeljust="l"; fontcolor="#5B8DBF"; fontsize=14; color="#5B8DBF"; style="rounded"; penwidth=1.6; margin=16;

    C_IN [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="💡\ncrees que terminaste un slice\n📜 → 🎯 Definición de LISTO"];
    C1 [color="#5B8DBF" penwidth=2.5 label="1 · 🔍  Verifica\nbuild + tests + lint según tu stack y\nCITA la salida real (0 errores); revisa\nAGENTS.md si tocaste capas\n+ QA de NO-REGRESIÓN visual (P13)"];
    C_DESTR [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿el diff ELIMINA funcionalidad /\nentidades / mucho código?"];
    C_PAUSA [color="#E08E45" label="🟠  PAUSA — es DESTRUCTIVO y NO transitivo\n(aunque un doc lo respalde): preséntalo como\nPÉRDIDA explícita y pide OK ANTES"];
    C_API [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿cambio de API / DTO /\nrepos / SQL?"];
    C_SMOKE [color="#5B8DBF" penwidth=2.5 label="smoke E2E (en Docker) al endpoint tocado\n— build+unit NO ven bugs de runtime"];
    C2 [color="#5B8DBF" penwidth=2.5 label="2 · 📝  Memoria + doc (misma tanda)\nestado-proyecto → HECHO; bitácora append «>>»;\ndoc=realidad (relee el encabezado, no solo\nla línea que tocaste)"];
    C3 [color="#5B8DBF" penwidth=2.5 label="3 · ✋  Confirma CON EL USUARIO\n¿el slice queda cerrado? el merge a\ndevelop NO va sin su OK expreso"];
    C4 [color="#5B8DBF" penwidth=2.5 label="4 · 🔗  Flujo de git\nramita → MR → develop con --squash\n(resumen curado en prosa, no el pegote)"];
    C5 [color="#5B8DBF" penwidth=2.5 label="5 · 🌱  Cosecha"];
    C_GEN [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿la lección / herramienta\nes GENÉRICA (no atada\na este proyecto)?"];
    C_PROM [color="#7FB069" label="🟢  promuévela a la skill / cerebro global\n(curación manual) + copia al repo las tools\nde scratch reusables (mueren al reiniciar)"];
    C_LOCAL [color="#7FB069" label="🟢  queda en la memoria del repo\n(no ensucies el global)"];

    C_IN -> C1;
    C1 -> C_DESTR;
    C_DESTR -> C_PAUSA [label="sí" color="#E08E45"];
    C_DESTR -> C_API   [label="no"];
    C_PAUSA -> C_API   [label="tras OK"];
    C_API -> C_SMOKE [label="sí"];
    C_API -> C2      [label="no"];
    C_SMOKE -> C2;
    C2 -> C3 -> C4 -> C5;
    C5 -> C_GEN;
    C_GEN -> C_PROM  [label="sí" color="#7FB069"];
    C_GEN -> C_LOCAL [label="no" color="#7FB069"];
  }

  // ===================== ⑦ DELEGAR un Task/agente (limite-gasto + delegacion-gate) =====================
  subgraph cluster_f6 {
    label="⑦ Delegar un Task/agente   (limite-gasto = FRENO · delegacion-gate = consentimiento)";
    labeljust="l"; fontcolor="#C0392B"; fontsize=14; color="#C0392B"; style="rounded"; penwidth=1.6; margin=16;

    G3_IN  [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="reclutar un agente (tool Task)\n📜 → 💰 Consentimiento de costo"];
    G3_D1  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n🛑  limite-gasto\n¿ventana 5h AGOTADA (≥99%)\nY overage SIN holgura?"];
    G3_FRENO [color="#C0392B" label="🔴  FRENO DURO — sin capacidad en\nningún lado; el agente moriría a medias.\nNO reintentar en auto (espera reset /\nmete saldo / hazlo tú)"];
    G3_D2  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="🔒\n💸  delegacion-gate\n¿hay jq para clasificar\nel costo?"];
    G3_ASK0 [color="#E08E45" label="🟠  ASK — no puedo clasificar;\n¿autorizas ESTA delegación?\n(fail-safe de gasto)"];
    G3_NIVEL [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿NIVEL de costo?\n(agentes-costo.json + snapshot\nde la ventana de 5h)"];
    G3_CG  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿ya consentido\nen ESTA compu?"];
    G3_CM  [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿ya consentido\nen ESTE workflow?"];
    G3_RUN1 [color="#7FB069" label="🟢  corre silencioso"];
    G3_COAL [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="G3 · fan-out paralelo:\n¿otro gate del MISMO lote (sesión+key)\nya tomó el lock atómico?"];
    G3_SIL  [color="#7FB069" label="🟢  pasa en SILENCIO (coalesced)\nel 1er ask del lote cubre a los hermanos\n→ mata el flood de N asks (solo gratis/incluido)"];
    G3_ASK1 [color="#E08E45" label="🟠  ASK 1×/compu\n(toma el lock · se recuerda por máquina)"];
    G3_RUN2 [color="#7FB069" label="🟢  corre silencioso"];
    G3_ASK2 [color="#E08E45" label="🟠  ASK 1×/workflow\n(se recuerda por sesión)"];
    G3_REG  [color="#E08E45" label="🔔\n📝  delegacion-registrar  (PostToolUse/Task)\ntras aprobar el ask y correr el agente, GRABA el consentimiento:\ngratis/incluido → por COMPU · metered → por WORKFLOW\n→ la próxima delegación corre SILENCIOSA (así se cumple «pregunta 1×»)"];

    G3_IN -> G3_D1;
    G3_D1 -> G3_FRENO [label="sí (AND)" color="#C0392B"];
    G3_D1 -> G3_D2    [label="no / sin snapshot (fail-open)"];
    G3_D2 -> G3_ASK0  [label="no" color="#E08E45"];
    G3_D2 -> G3_NIVEL [label="sí"];
    G3_NIVEL -> G3_CG [label="gratis (local) /\nincluido (Claude en ventana)"];
    G3_NIVEL -> G3_CM [label="metered (overage /\nexterno / desconocido)"];
    G3_CG -> G3_RUN1 [label="sí" color="#7FB069"];
    G3_CG -> G3_COAL [label="no (aún sin consentir)"];
    G3_COAL -> G3_SIL  [label="sí (soy hermano)" color="#7FB069"];
    G3_COAL -> G3_ASK1 [label="no (soy el 1º del lote)" color="#E08E45"];
    G3_CM -> G3_RUN2 [label="sí" color="#7FB069"];
    G3_CM -> G3_ASK2 [label="no (metered NO se coalesce:\ncada uno confirma)" color="#E08E45"];
    G3_ASK1 -> G3_REG [label="apruebas → corre" color="#E08E45"];
    G3_ASK2 -> G3_REG [label="apruebas → corre" color="#E08E45"];
  }

  // ===================== ⑧ ORQUESTAR UN FAN-OUT (sin niñera · orquestar-fanout) =====================
  subgraph cluster_f7 {
    label="⑧ Orquestar un fan-out · sin niñera   (orquestar-fanout · skill)";
    labeljust="l"; fontcolor="#5B8DBF"; fontsize=14; color="#5B8DBF"; style="rounded"; penwidth=1.6; margin=16;

    OF_IN [shape=box color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="💡\ntrabajo PARALELIZABLE\n(varias piezas independientes)"];
    OF_1  [color="#5B8DBF" penwidth=2.5 label="1 · 📋  Asigna del backlog\n(estado-proyecto.md = fuente de verdad;\nreparte archivos disjuntos por agente)\ninicia el agente EN el repo destino (P6) · latido con agentes en vuelo (P4)\n📜 → 🎼 Orquesta"];
    OF_DAUTO [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿el ítem es AUTOCONTENIDO?\n(no depende de otro\nagente en vuelo)"];
    OF_SER [color="#E08E45" label="🟠  serialízalo o únelo\n(no lo delegues suelto)"];
    OF_DMUT [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿el agente MUTA\narchivos / commitea?"];
    OF_WT [color="#E08E45" label="🔔\n🌳  WORKTREE AISLADO (isolation: worktree)\nnunca el árbol compartido; si no se puede\naislar, lo hace el orquestador\n(proteger-arbol respalda)\n📜 → 🧱 Aislamiento de fan-out"];
    OF_DEPLOY [color="#E08E45" label="🟠  y NUNCA deployes desde ese worktree:\nno hereda gitignored → rompe el deploy.\nEl deploy sale del clon PRINCIPAL tras git pull"];
    OF_GATE [color="#C0392B" penwidth=2.5 label="🔒\n💸  delegacion-gate\nconsentimiento de costo (ver flujo ⑦)"];
    OF_AG [color="#D97757" fillcolor="#2B2622" penwidth=2.5 label="🤖  agente TERMINAL — ejecuta el trabajo\nCOMPLETO en su turno (no background);\ndevuelve: qué hizo · línea-bitácora ·\npendiente · estado del worktree\nPORTA, no REHAGAS: cita+lee la fuente antes de escribir (P2)"];
    OF_DVER [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="orquestador VERIFICA read-only\n(git / archivo / compila):\n¿el resultado real existe?"];
    OF_NO [color="#C0392B" label="🔴  NO lo marques hecho\n(el reporte NO es evidencia: pudo\ndevolver un stub o alucinar «background»)"];
    OF_CIERRE [color="#5B8DBF" penwidth=2.5 label="cierre AUTOMÁTICO al terminar\n(lo recuerda 🔔 delegacion-reporte):\n🟢 APPENDA a bitácora.md (con «>>»)\n🟢 cierra el ítem en estado-proyecto.md"];
    OF_WTC [color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5 label="⚙  limpiar-worktrees.sh"];
    OF_DWT [shape=diamond fillcolor="#2B2622" color="#D97757" penwidth=2 label="¿la rama del worktree\nya está mergeada?"];
    OF_BORRA [color="#7FB069" label="🟢  borra el worktree"];
    OF_DEJA [color="#E08E45" label="🟠  déjalo + anota su\npendiente en la bitácora"];

    OF_IN -> OF_1 -> OF_DAUTO;
    OF_DAUTO -> OF_SER  [label="no" color="#E08E45"];
    OF_DAUTO -> OF_DMUT [label="sí"];
    OF_DMUT -> OF_WT   [label="sí"];
    OF_DMUT -> OF_GATE [label="no (read-only)"];
    OF_WT -> OF_GATE;
    OF_WT -> OF_DEPLOY [label="ojo" color="#E08E45" style=dashed];
    OF_GATE -> OF_AG;
    OF_AG -> OF_DVER;
    OF_DVER -> OF_NO     [label="no" color="#C0392B"];
    OF_DVER -> OF_CIERRE [label="sí" color="#7FB069"];
    OF_CIERRE -> OF_WTC;
    OF_WTC -> OF_DWT;
    OF_DWT -> OF_BORRA [label="sí" color="#7FB069"];
    OF_DWT -> OF_DEJA  [label="no" color="#E08E45"];
  }

  // ===================== 📜 NORMAS — el cimiento (el porqué que los flujos hacen cumplir) =====================
  subgraph cluster_normas {
    label="📜 NORMAS · el cimiento   (el porqué; cada flujo de arriba las hace cumplir)";
    labeljust="l"; fontcolor="#7FB069"; fontsize=14; color="#7FB069"; style="rounded"; penwidth=1.6; margin=16;
    node [color="#7FB069" penwidth=2];
    N_DOD  [label="📜\n🎯  Definición de LISTO\nverde técnico ≠ LISTO (build+tests+memoria es\nnecesario pero NO suficiente): falta (1) QA del\nusuario o (2) su OK expreso de cierre\nproducto INSTALABLE: verde en 1 máquina ≠ LISTO (checklist multi-OS · P3)\n— hecho cumplir en ⑤ ⑥ ②"];
    N_GIT  [label="📜\n🌿  Flujo de git\nramita → MR → develop (con squash); main es\nrelease-only; NUNCA push directo a develop/main\nel gate confirmar ≠ «no puedes»: con tu OK, Claude mergea por CLI (P7)\n— hecho cumplir en ② ③"];
    N_DOC  [label="📜\n🪞  doc = realidad\nal cambiar algo, su doc se actualiza en la MISMA\ntanda (README/memoria/dashboard/comentarios)\n— hecho cumplir en ④"];
    N_MINI [label="📜\n🌱  Modelo MINI-DEVELOP\nramitas → rama personal/integración por merge\nLOCAL (sin fricción); solo el MR a develop se gatea\n— habilitado en ②"];
    N_COST [label="📜\n💰  Consentimiento de costo de delegación\ndelegar cuesta por nivel: gratis (local) / incluido\n(ventana 5h) / metered (overage o API externa)\n— hecho cumplir en ⑦"];
    N_ORQ  [label="📜\n🎼  Orquesta: delega y quédate en el loop\ncon trabajo paralelizable: fan-out + supervisión\n(no grind serial); auto-reporte sin niñera\n— operacionalizada en ⑧"];
    N_AISL [label="📜\n🧱  Aislamiento de fan-out\ntodo agente que MUTA/commitea corre en worktree\nAISLADO, nunca en el árbol de trabajo compartido\n— hecho cumplir en ③ ⑧"];
    N_P0   [color="#D97757" penwidth=2.5 style="rounded,filled"
            label="🛡\nIntegridad de los guardarraíles (P0 · activa)\nClaude NO afloja sus propios candados de supervisión\npara desatorarse; cambiar un control exige el OK\nEXPLÍCITO a cambiar ESE control (≠ el OK a la acción)\n— protege dod-verificar ⑤ · confirmar/squash/branch ② · proteger-arbol ③"];
    N_MEC  [label="📜\n🧩  Toda norma nace con su mecanismo (P8)\nuna norma de higiene/cierre SIN hook/gate/paso operativo\n= el usuario es el enforcement → no se cumple sola"];

    N_P0 -> N_DOD [label="protege" style=dashed color="#D97757" fontcolor="#D97757" penwidth=1.4 constraint=false];
    N_P0 -> N_GIT [style=dashed color="#D97757" penwidth=1.4 constraint=false];
    // apila las normas en COLUMNA (invisible: solo rango) para que no se vayan a lo ancho
    edge [style=invis];
    N_TPL  [label="📜\n🧬  Al templatizar: DOMINIO vs regla genérica (P9)\nal derivar un template de un concreto, quita el dominio pero\nCONSERVA las reglas genéricas (diff PORTAR-vs-OK-EXCLUIDO)"];
    N_P0 -> N_DOD -> N_GIT -> N_DOC -> N_MINI -> N_COST -> N_ORQ -> N_AISL -> N_MEC -> N_TPL;
    edge [style=solid];
  }

  // ===================== 🔩 REFERENCIA · lib/skill de stack (sin flujo propio) =====================
  subgraph cluster_ref {
    label="🔩 REFERENCIA · lib/skill de stack (sin flujo propio)";
    labeljust="l"; fontcolor="#8A8A8A"; fontsize=14; color="#8A8A8A"; style="rounded"; penwidth=1.4; margin=14;
    R_COMUN [color="#8A8A8A" fillcolor="#232323" fontcolor="#CFC8C0" penwidth=1.5
             label="⚙\ndelegacion-comun  (lib)\nclasificación de costo compartida (fuente ÚNICA):\nla usan delegacion-gate Y delegacion-registrar (⑦)"];
    R_NET   [color="#5B8DBF" penwidth=2.5
             label="💡\nskills .NET (plantilla, específicas de stack)\ncrear-pagina-blazor · migracion-ef · build-produccion ·\nagregar-seed… (usan el ritual cerrar-slice, ⑥)"];
    R_COMUN -> R_NET [style=invis];   // apílalos en columna
  }

  // (El acomodo espacial —normas/referencia DEBAJO de los flujos— se hace en yEd; Graphviz solo fija el CONTENIDO.)
  // (Las referencias a 📜 normas / 💡 skills van como TAG de texto DENTRO del nodo que las invoca — ver labels arriba.)

  // ===== CORRELACIÓN ⑤↔⑥: la evidencia (1)/(2) que dod-verificar EXIGE es la que cerrar-slice PRODUCE =====

  // ===== CORRELACIÓN ⑤↔⑥: la evidencia (1)/(2) que dod-verificar EXIGE es la que cerrar-slice PRODUCE =====
  // (adyacentes por el orden de familia → conector corto; constraint=false para no alterar el layout)
  C3 -> G2_D4 [dir=both color="#D97757" style=dashed penwidth=1.4 constraint=false
               label="misma evidencia (1)/(2):\n⑥ la produce · ⑤ la exige"];
}
