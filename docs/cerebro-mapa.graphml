    <edge source="H_SQUASH" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#3333FF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>2) --squash ok</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="O_MERGE_OK"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#3333FF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>3) OK explicito</y:EdgeLabel></y:PolyLineEdge></data></edge>

