<?xml version="1.0" encoding="UTF-8"?>
<!-- Mapa del cerebro claude-brain: jerarquías, relaciones y flujos de decisión.
     Abrir en yEd. Recomendado: Layout > Hierarchical (o Organic) tras abrir.
     Colores: verde=NORMA · rojo=hook BLOQUEADOR · ámbar=hook NUDGE(avisa) · azul=SKILL
     gris=lib/helper · amarillo-diamante=DECISIÓN · verde/rojo/ámbar-elipse=RESULTADO. -->
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:y="http://www.yworks.com/xml/graphml"
         xmlns:yed="http://www.yworks.com/xml/yed/3"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://www.yworks.com/xml/schema/graphml/1.1/ygraphml.xsd">
  <key id="d0" for="node" yfiles.type="nodegraphics"/>
  <key id="d1" for="edge" yfiles.type="edgegraphics"/>
  <key id="dd" for="node" attr.name="description" attr.type="string"/>
  <graph id="cerebro" edgedefault="directed">

    <!-- ===================== LEYENDA ===================== -->
    <node id="LEG">
      <data key="dd">Leyenda del mapa</data>
      <data key="d0"><y:ShapeNode>
        <y:Geometry height="150" width="330"/>
        <y:Fill color="#FFFFCC"/><y:BorderStyle color="#999999"/>
        <y:NodeLabel alignment="left">LEYENDA&#10;verde  = NORMA (regla que Claude se autoimpone)&#10;rojo   = hook BLOQUEADOR (deny)&#10;ambar  = hook NUDGE (avisa/inyecta, no bloquea)&#10;azul   = SKILL (opt-in)&#10;gris   = lib / helper&#10;diamante amarillo = DECISION&#10;elipse = RESULTADO (DENY / ALLOW / ASK / WARN)&#10;--- flecha llena: relacion  ·  --- punteada: protege/source</y:NodeLabel>
        <y:Shape type="roundrectangle"/>
      </y:ShapeNode></data>
    </node>

    <!-- ===================== NORMAS (verde) ===================== -->
    <node id="N_DOD"><data key="dd">Definicion de LISTO</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: Definicion de LISTO&#10;(verde tecnico != LISTO)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_DOC"><data key="dd">doc=realidad</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: doc = realidad&#10;(actualiza la doc en la tanda)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_GIT"><data key="dd">Flujo de git</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: Flujo de git&#10;ramita-MR-develop; main release-only</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_MINI"><data key="dd">Modelo MINI-DEVELOP</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: MINI-DEVELOP&#10;(iterar sin friccion)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_COST"><data key="dd">Consentimiento de costo de delegacion</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: Costo de delegacion&#10;(gratis/incluido/metered)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_ORQ"><data key="dd">Orquesta: delega y quedate en el loop</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: Orquesta&#10;(fan-out + supervision)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_AISL"><data key="dd">Aislamiento de fan-out</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="185"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>NORMA: Aislamiento de fan-out&#10;(agente que muta = worktree aislado)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="N_P0"><data key="dd">P0 PROPUESTA: Integridad de los guardarrailes</data><data key="d0"><y:ShapeNode><y:Geometry height="55" width="210"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366" type="dashed" width="2.0"/><y:NodeLabel>NORMA P0 (PROPUESTA): Integridad&#10;de los guardarrailes -- Claude NO&#10;afloja sus propios candados para&#10;desatorarse</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>

    <!-- ===================== HOOKS BLOQUEADORES (rojo) ===================== -->
    <node id="H_BRANCH"><data key="dd">git-branch-guard</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>git-branch-guard (Bash)&#10;push/merge a develop/main -&gt; DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SQUASH"><data key="dd">merge-squash-guard</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>merge-squash-guard (Bash)&#10;MR a develop sin --squash -&gt; DENY&#10;(main/release EXENTO)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_CONF"><data key="dd">confirmar-merge-develop (repo-scoped, compartido)</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>confirmar-merge-develop (Bash)&#10;merge a develop/main sin OK -&gt; DENY&#10;(solo repos con .claude/repo-compartido)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_DOD"><data key="dd">dod-verificar (Stop, repo-scoped)</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>dod-verificar (Stop)&#10;LISTO sin evidencia -&gt; DENY;&#10;claim visual a ciegas -&gt; DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SECRET"><data key="dd">secret-scan</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>secret-scan (Bash)&#10;commit/push con secreto -&gt; DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_LIMITE"><data key="dd">limite-gasto</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>limite-gasto (Task)&#10;sin ventana 5h Y sin overage -&gt; FRENO</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_GATE"><data key="dd">delegacion-gate</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>delegacion-gate (Task)&#10;delegar con costo -&gt; pide OK (ASK)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===================== HOOKS NUDGE (ambar) ===================== -->
    <node id="H_DASH"><data key="dd">recordar-dashboard</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>recordar-dashboard (Bash)&#10;en push: dashboard + doc=realidad</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_RAMA"><data key="dd">rama-vieja</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>rama-vieja (Bash)&#10;avisa si la ramita arrastra base vieja</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_ARBOL"><data key="dd">proteger-arbol</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>proteger-arbol (Bash)&#10;git destructivo que orfanaria&#10;commits sin pushear -&gt; AVISA</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REG"><data key="dd">delegacion-registrar</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>delegacion-registrar (Task)&#10;materializa "pregunta una sola vez"</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_REP"><data key="dd">delegacion-reporte</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>delegacion-reporte (Task)&#10;al terminar agente: registrar&#10;avance + limpiar worktree</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_SESION"><data key="dd">sesion-inicio (repo-scoped)</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>sesion-inicio (SessionStart)&#10;reinyecta rama+norma+memoria</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="H_PRECOMP"><data key="dd">precompact-volcar-estado (repo-scoped)</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="180"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>precompact-volcar-estado (PreCompact)&#10;vuelca estado antes de compactar</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===================== LIBS / HELPERS (gris) ===================== -->
    <node id="L_COMUN"><data key="dd">delegacion-comun (lib)</data><data key="d0"><y:ShapeNode><y:Geometry height="35" width="150"/><y:Fill color="#F5F5F5"/><y:BorderStyle color="#666666"/><y:NodeLabel>delegacion-comun (lib)&#10;clasificacion de costo</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="L_WT"><data key="dd">limpiar-worktrees.sh (helper)</data><data key="d0"><y:ShapeNode><y:Geometry height="35" width="150"/><y:Fill color="#F5F5F5"/><y:BorderStyle color="#666666"/><y:NodeLabel>limpiar-worktrees.sh&#10;(helper: barre zombies)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===================== SKILLS (azul) ===================== -->
    <node id="S_CERRAR"><data key="dd">cerrar-slice</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="170"/><y:Fill color="#DAE8FC"/><y:BorderStyle color="#6C8EBF"/><y:NodeLabel>SKILL: cerrar-slice&#10;ritual de cierre (evidencia+flujo)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_FANOUT"><data key="dd">orquestar-fanout</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="170"/><y:Fill color="#DAE8FC"/><y:BorderStyle color="#6C8EBF"/><y:NodeLabel>SKILL: orquestar-fanout&#10;fan-out sin niñera</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="S_NET"><data key="dd">skills .NET de plantilla</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="170"/><y:Fill color="#DAE8FC"/><y:BorderStyle color="#6C8EBF"/><y:NodeLabel>SKILLS .NET (plantilla)&#10;crear-pagina-blazor, migracion-ef,&#10;build-produccion, agregar-seed...</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===================== DECISIONES (diamante amarillo) + RESULTADOS ===================== -->
    <node id="D_MERGE"><data key="dd">Decision: integrar a develop/main</data><data key="d0"><y:ShapeNode><y:Geometry height="70" width="150"/><y:Fill color="#FFF2CC"/><y:BorderStyle color="#D6B656"/><y:NodeLabel>DECISION&#10;Integrar rama&#10;a develop/main?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="O_MERGE_OK"><data key="dd">merge realizado</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>ALLOW: ramita+MR+squash&#10;+ OK explicito -&gt; merge</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>

    <node id="D_CIERRE"><data key="dd">Decision: declarar cierre (Stop)</data><data key="d0"><y:ShapeNode><y:Geometry height="70" width="150"/><y:Fill color="#FFF2CC"/><y:BorderStyle color="#D6B656"/><y:NodeLabel>DECISION (fin de turno)&#10;Lenguaje de&#10;CIERRE?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="O_ESCAPE"><data key="dd">no dispara</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>OK: status/pregunta/en-preview&#10;-&gt; no dispara</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="O_BLOCK_DOD"><data key="dd">bloqueo LISTO</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>DENY: codigo tocado + sin (1)/(2)&#10;o claim visual a ciegas</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>

    <node id="D_DELEG"><data key="dd">Decision: delegar agente</data><data key="d0"><y:ShapeNode><y:Geometry height="70" width="150"/><y:Fill color="#FFF2CC"/><y:BorderStyle color="#D6B656"/><y:NodeLabel>DECISION&#10;Delegar un&#10;Task/agente?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="O_ASK"><data key="dd">pide OK de costo</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>ASK: consentimiento por ventana&#10;(1x/compu o 1x/workflow)</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>
    <node id="O_FRENO"><data key="dd">freno de gasto</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#F8CECC"/><y:BorderStyle color="#B85450"/><y:NodeLabel>FRENO: ventana 5h agotada&#10;Y overage sin holgura</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>

    <node id="D_DESTR"><data key="dd">Decision: git destructivo</data><data key="d0"><y:ShapeNode><y:Geometry height="70" width="150"/><y:Fill color="#FFF2CC"/><y:BorderStyle color="#D6B656"/><y:NodeLabel>DECISION&#10;git reset --hard /&#10;checkout -f / rebase?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="O_WARN"><data key="dd">aviso de orfanar</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="150"/><y:Fill color="#FFE6CC"/><y:BorderStyle color="#D79B00"/><y:NodeLabel>WARN: orfanaria commits&#10;sin pushear -&gt; usa worktree aislado</y:NodeLabel><y:Shape type="ellipse"/></y:ShapeNode></data></node>

    <!-- Fan-out mini-flujo -->
    <node id="F_ASIGNA"><data key="dd">orquestador asigna item autocontenido</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="160"/><y:Fill color="#DAE8FC"/><y:BorderStyle color="#6C8EBF"/><y:NodeLabel>Orquestador asigna item&#10;autocontenido (files disjuntos)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F_AGENTE"><data key="dd">agente en worktree aislado</data><data key="d0"><y:ShapeNode><y:Geometry height="40" width="160"/><y:Fill color="#FFF2CC"/><y:BorderStyle color="#D6B656"/><y:NodeLabel>Agente en WORKTREE AISLADO&#10;(terminal: ejecuta en su turno)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F_CIERRE"><data key="dd">cierre automatico del agente</data><data key="d0"><y:ShapeNode><y:Geometry height="45" width="160"/><y:Fill color="#D5E8D4"/><y:BorderStyle color="#82B366"/><y:NodeLabel>Cierre auto: appenda bitacora&#10;+ actualiza estado-proyecto&#10;+ limpia worktree</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===================== EDGES: enforce (hook -> norma) ===================== -->
    <edge source="H_BRANCH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_SQUASH" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_GIT"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_CONF" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce (al integrar)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DOD" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce (al declarar)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_DASH" target="N_DOC"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>recuerda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_GATE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_LIMITE" target="N_COST"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>enforce</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_ARBOL" target="N_AISL"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="H_REP" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:Arrows source="none" target="standard"/><y:EdgeLabel>respalda</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <!-- P0 protege los guards (punteada) -->
    <edge source="N_P0" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>protege integridad</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#6C8EBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#6C8EBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_BRANCH"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#6C8EBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="N_P0" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#6C8EBF"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <!-- SKILLS usan hooks/helpers -->
    <edge source="S_CERRAR" target="H_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa (bidir)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_DASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa (bidir)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="H_BRANCH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_REP"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa (bidir)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_GATE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="H_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="L_WT"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>usa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_FANOUT" target="N_ORQ"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="S_CERRAR" target="N_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#6C8EBF"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>materializa</y:EdgeLabel></y:PolyLineEdge></data></edge>

    <!-- libs: source / dispara -->
    <edge source="H_GATE" target="L_COMUN"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#666666"/><y:Arrows source="none" target="standard"/><y:EdgeLabel>source</y:EdgeLabel></y:PolyLineEdge></data></edge>
