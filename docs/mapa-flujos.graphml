<?xml version="1.0" encoding="UTF-8"?>
<!-- Mapa del cerebro claude-brain — FLUJOS DE DECISIÓN (las relaciones/jerarquía van en mapa-relaciones.graphml).
     Lenguaje visual del README/widget: grafito + terracota (#D97757), emoji, diamante=decisión.
     RESULTADOS en rectángulo redondeado (no elipse: acomoda el texto sin cortar).
     4 flujos + fan-out. Abrir en yEd -> Layout > Hierarchical (Top-to-Bottom). -->
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:y="http://www.yworks.com/xml/graphml"
         xmlns:yed="http://www.yworks.com/xml/yed/3"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://www.yworks.com/xml/schema/graphml/1.1/ygraphml.xsd">
  <key id="d0" for="node" yfiles.type="nodegraphics"/>
  <key id="d1" for="edge" yfiles.type="edgegraphics"/>
  <graph id="flu" edgedefault="directed">

    <node id="TIT"><data key="d0"><y:ShapeNode><y:Geometry height="96" width="330"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.0"/><y:NodeLabel alignment="left" textColor="#F2EDE6">🧠 claude-brain — FLUJOS DE DECISIÓN&#10;&#10;🔶 diamante = decisión · 🔴 hook que evalúa&#10;🟢 ALLOW · 🔴 DENY · 🟠 ASK/WARN&#10;— flecha terracota = camino de decisión</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== FLUJO 1: integrar a develop/main ===== -->
    <node id="D_MERGE"><data key="d0"><y:ShapeNode><y:Geometry height="72" width="160"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔶 ¿Integrar rama&#10;a develop/main?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="F1_BRANCH"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🚧 git-branch-guard</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_SQUASH"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔗 merge-squash-guard</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_CONF"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✋ confirmar-merge-develop</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_DENYB"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="250"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 push directo → DENY (usa ramita+MR)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_DENYS"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="250"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 sin --squash → DENY (main EXENTO)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_DENYC"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="250"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 sin OK explícito → DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F1_OK"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="250"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟢 con OK + squash → MERGE</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== FLUJO 2: declarar cierre (Stop/DoD) ===== -->
    <node id="D_CIERRE"><data key="d0"><y:ShapeNode><y:Geometry height="72" width="160"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔶 Fin de turno:&#10;¿lenguaje de CIERRE?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="F2_DOD"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">✅ dod-verificar (Stop)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F2_ESC"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="270"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟢 status/pregunta/en-preview → no dispara</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F2_VIS"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="280"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 claim visual sin tool de navegador → DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F2_DENY"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="270"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 código tocado + sin (1)/(2) → DENY</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F2_OK"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="280"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟢 (1) QA confirmado o (2) OK explícito → cierra</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== FLUJO 3: delegar / costo ===== -->
    <node id="D_DELEG"><data key="d0"><y:ShapeNode><y:Geometry height="72" width="160"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔶 ¿Delegar un&#10;Task/agente?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="F3_GATE"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">💸 delegacion-gate</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F3_LIM"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🛑 limite-gasto</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F3_ASK"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="290"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟠 hay costo → ASK (1×/compu o 1×/workflow)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F3_FRENO"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="290"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#C0392B" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🔴 ventana 5h Y overage agotados → FRENO</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== FLUJO 4: git destructivo ===== -->
    <node id="D_DESTR"><data key="d0"><y:ShapeNode><y:Geometry height="72" width="170"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🔶 ¿git reset --hard /&#10;checkout -f / rebase?</y:NodeLabel><y:Shape type="diamond"/></y:ShapeNode></data></node>
    <node id="F4_ARBOL"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🌳 proteger-arbol</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="F4_WARN"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="300"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟠 orfanaría commits sin pushear → AVISA (usa worktree)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== FLUJO fan-out ===== -->
    <node id="FO_SKILL"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="185"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.5"/><y:NodeLabel textColor="#F2EDE6">🧵 orquestar-fanout</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="FO_ASIGNA"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="215"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#5B8DBF" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📋 asigna ítem autocontenido (files disjuntos)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="FO_AGENTE"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="240"/><y:Fill color="#2B2622"/><y:BorderStyle color="#D97757" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🤖 agente en WORKTREE AISLADO (terminal: ejecuta en su turno)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="FO_CIERRE"><data key="d0"><y:ShapeNode><y:Geometry height="46" width="250"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#7FB069" width="2.0"/><y:NodeLabel textColor="#F2EDE6">🟢 cierre auto: bitácora + estado-proyecto + limpiar worktree</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>
    <node id="FO_REP"><data key="d0"><y:ShapeNode><y:Geometry height="42" width="195"/><y:Fill color="#2B2B2B"/><y:BorderStyle color="#E08E45" width="2.0"/><y:NodeLabel textColor="#F2EDE6">📮 delegacion-reporte (lo recuerda)</y:NodeLabel><y:Shape type="roundrectangle"/></y:ShapeNode></data></node>

    <!-- ===== EDGES (terracota) ===== -->
    <edge source="D_MERGE" target="F1_BRANCH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F1_BRANCH" target="F1_DENYB"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F1_BRANCH" target="F1_SQUASH"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#B0A89F">ok (via MR)</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="F1_SQUASH" target="F1_DENYS"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F1_SQUASH" target="F1_CONF"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#B0A89F">--squash ok</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="F1_CONF" target="F1_DENYC"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F1_CONF" target="F1_OK"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <edge source="D_CIERRE" target="F2_DOD"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F2_DOD" target="F2_ESC"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#7FB069"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F2_DOD" target="F2_VIS"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F2_DOD" target="F2_DENY"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F2_DOD" target="F2_OK"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#7FB069"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <edge source="D_DELEG" target="F3_GATE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F3_GATE" target="F3_ASK"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#E08E45"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="D_DELEG" target="F3_LIM"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F3_LIM" target="F3_FRENO"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#C0392B"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <edge source="D_DESTR" target="F4_ARBOL"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="F4_ARBOL" target="F4_WARN"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#E08E45"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>

    <edge source="FO_SKILL" target="FO_ASIGNA"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/></y:PolyLineEdge></data></edge>
    <edge source="FO_ASIGNA" target="FO_AGENTE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#B0A89F">delega</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="FO_AGENTE" target="FO_CIERRE"><data key="d1"><y:PolyLineEdge><y:LineStyle color="#D97757" width="1.5"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#B0A89F">al terminar</y:EdgeLabel></y:PolyLineEdge></data></edge>
    <edge source="FO_REP" target="FO_CIERRE"><data key="d1"><y:PolyLineEdge><y:LineStyle type="dashed" color="#E08E45"/><y:Arrows source="none" target="standard"/><y:EdgeLabel textColor="#B0A89F">recuerda</y:EdgeLabel></y:PolyLineEdge></data></edge>

  </graph>
</graphml>
