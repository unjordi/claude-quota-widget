*.swp
*.swo
.DS_Store
/build/
/dist/

# --- Cerebro de Claude Code (convención proyecto-autocontenido) ---
# transcripts de sesión: pesados y pueden traer datos sensibles
.claude/transcripts/
.claude/*.jsonl
# config específica de la máquina
.claude/settings.local.json
# memorias personales/sensibles que NO viajan al equipo
.claude/memory/*.local.md

# brain/ empaquetado en el plasmoid al instalar (Linux) — temporal, no versionar
src/plasmoid/contents/brain/
# version.json embebido en el plasmoid al instalar (autoupdate) — temporal, no versionar
src/plasmoid/contents/version.json

# El graphml del mapa del cerebro es artefacto regenerable (bin/dot2yed.py); no se versiona.
docs/mapa-flujos.graphml
# El png del mapa es regenerable (dot -Tpng); el repo versiona .dot (fuente) + .svg (vista).
docs/mapa-flujos.png
# reporte de bug para Claude Code (worktree isolation): artefacto LOCAL de un solo uso (se fila externamente), NO se versiona en el brain compartible
docs/bug-report-worktree-base.md
# Docs de PLANIFICACION/AUDITORIA/DISENO (narrativa de debugging; NO describen el codigo) -> locales, no se versionan
docs/plan-refactor-desacople.md
docs/auditoria-flowcharts.md
docs/mapa-flujos.dot
docs/mapa-flujos.svg

# memoria de dev PRIVADA del widget (historia de debugging/backlog; NO describe el código y NO viaja a repos consumidores)
.claude/memory/backlog-desarrollo.md

# flowcharts individuales (derivados del mapa, también gitignored) — artefactos locales de visualización
docs/flowcharts/
