#!/usr/bin/env bash
# Fetches Claude Code 5-hour and weekly usage and writes a normalized JSON
# snapshot to ~/.cache/claude-quota/state.json.
#
# Primary source: Anthropic's OAuth usage endpoint — the same data `/usage`
# shows inside Claude Code, read with the OAuth token Claude Code already
# stores in ~/.claude/.credentials.json. This gives the EXACT utilization
# percentages and reset times for your plan; no calibration.
#
# Fallback (offline / no credentials): ccusage cost-basis estimation against
# the *_CAP_USD calibration constants below. ccusage is also still used to
# enrich the snapshot with API-equivalent $ figures when available.
#
# Override defaults by exporting in ~/.config/claude-quota/limits.env
# (the systemd unit sources it).

set -euo pipefail

# FALLBACK calibration only — used when the OAuth endpoint is unreachable.
# Basis = API-equivalent *cost*, not raw tokens (cache-read tokens dominate
# raw counts and are weighted ~0.1x by Anthropic's limits). Calibrate against
# /usage: CAP = ($ shown in popup) / (/usage fraction). Defaults: Max-20x.
FIVE_HOUR_CAP_USD="${FIVE_HOUR_CAP_USD:-150}"
WEEKLY_CAP_USD="${WEEKLY_CAP_USD:-9000}"
WARN_PCT="${WARN_PCT:-60}"
CRIT_PCT="${CRIT_PCT:-85}"

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/claude-quota"
STATE_FILE="$CACHE_DIR/state.json"
TMP_FILE="$CACHE_DIR/state.json.tmp"

mkdir -p "$CACHE_DIR"

write_error() {
  local msg="$1"
  jq -n --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --arg err "$msg" '{
    updated_at: $ts,
    status: "error",
    error: $err,
    five_hour: null,
    weekly: null
  }' > "$TMP_FILE"
  mv "$TMP_FILE" "$STATE_FILE"
}

# --- Primary: the OAuth usage endpoint /usage itself reads -------------------

oauth_token() {
  [[ -r "$HOME/.claude/.credentials.json" ]] || return 1
  jq -er '.claudeAiOauth.accessToken // empty' "$HOME/.claude/.credentials.json"
}

USAGE_JSON=""
if TOKEN="$(oauth_token 2>/dev/null)" && [[ -n "$TOKEN" ]]; then
  USAGE_JSON="$(curl -fsS -m 15 "https://api.anthropic.com/api/oauth/usage" \
    -H "Authorization: Bearer $TOKEN" \
    -H "anthropic-beta: oauth-2025-04-20" 2>/dev/null || true)"
  # Sanity check: must be JSON carrying the 5-hour utilization.
  if ! jq -e '.five_hour.utilization != null' <<<"$USAGE_JSON" >/dev/null 2>&1; then
    USAGE_JSON=""
  fi
fi

# --- Secondary: ccusage (cost enrichment, and fallback percentages) ----------

resolve_ccusage() {
  if command -v ccusage >/dev/null 2>&1; then
    echo "ccusage"
  elif command -v npx >/dev/null 2>&1; then
    echo "npx -y ccusage@latest"
  else
    return 1
  fi
}

CCUSAGE="$(resolve_ccusage || true)"

# Live pricing first: the bundled --offline table lags new models, whose
# tokens are then costed at $0 — silently deflating both the $ enrichment
# and the fallback percentages. --offline is the no-network retry.
ccusage_json() {
  local out
  out="$($CCUSAGE "$@" 2>/dev/null || true)"
  [[ -z "$out" ]] && out="$($CCUSAGE "$@" --offline 2>/dev/null || true)"
  printf '%s' "$out"
}

BLOCKS_JSON=""
WEEKLY_JSON=""
if [[ -n "$CCUSAGE" ]]; then
  BLOCKS_JSON="$(ccusage_json blocks --json --active)"
  SINCE="$(date -u -d '8 days ago' +%Y%m%d)"
  WEEKLY_JSON="$(ccusage_json weekly --json --since "$SINCE")"
  # Discard anything that isn't valid JSON so jq --argjson can't blow up.
  jq -e . <<<"$BLOCKS_JSON" >/dev/null 2>&1 || BLOCKS_JSON=""
  jq -e . <<<"$WEEKLY_JSON" >/dev/null 2>&1 || WEEKLY_JSON=""
fi

if [[ -z "$USAGE_JSON" && -z "$BLOCKS_JSON" && -z "$WEEKLY_JSON" ]]; then
  write_error "no data: OAuth usage endpoint unreachable and ccusage returned nothing"
  exit 0
fi

NOW_ISO="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
# ccusage groups weeks Monday-start; compute this week's Monday so we pick the
# CURRENT week bucket (the array is oldest-first, so [0] is last week).
DOW="$(date -u +%u)"  # 1=Mon..7=Sun
CURRENT_MONDAY="$(date -u -d "$((DOW - 1)) days ago" +%Y-%m-%d)"
# Fallback weekly reset when the OAuth endpoint (which knows the real rolling
# reset) is unavailable.
NEXT_MONDAY="$(date -u -d "next Monday 00:00:00" +%Y-%m-%dT%H:%M:%SZ)"

jq -n \
  --argjson usage "${USAGE_JSON:-null}" \
  --argjson blocks "${BLOCKS_JSON:-null}" \
  --argjson weekly "${WEEKLY_JSON:-null}" \
  --arg ts "$NOW_ISO" \
  --arg cur_week "$CURRENT_MONDAY" \
  --arg next_monday "$NEXT_MONDAY" \
  --argjson five_cap "$FIVE_HOUR_CAP_USD" \
  --argjson week_cap "$WEEKLY_CAP_USD" \
  --argjson warn "$WARN_PCT" \
  --argjson crit "$CRIT_PCT" '
  def pct(used; cap): if cap > 0 then (used * 100 / cap) else 0 end;
  def round1(x): (x * 10 | floor) / 10;
  def round2(x): (x * 100 | floor) / 100;
  # "2026-06-10T00:00:00.070837+00:00" -> "2026-06-10T00:00:00Z"
  def isoz: sub("\\.[0-9]+"; "") | sub("\\+00:00$"; "Z");

  ($blocks.blocks[0] // null) as $blk
  | ([$weekly.weekly[]? | select((.week // .period) == $cur_week)] | first) as $wk
  | (if $blocks != null then round2(if $blk then ($blk.costUSD // 0) else 0 end) else null end) as $five_cost
  | (if $weekly != null then round2(if $wk then ($wk.totalCost // 0) else 0 end) else null end) as $week_cost
  | (if $usage != null then ($usage.five_hour.utilization // 0)
     else pct($five_cost // 0; $five_cap) end) as $five_pct
  | (if $usage != null then ($usage.seven_day.utilization // 0)
     else pct($week_cost // 0; $week_cap) end) as $week_pct
  | ([$five_pct, $week_pct] | max) as $max_pct
  | (if $max_pct >= $crit then "crit"
     elif $max_pct >= $warn then "warn"
     else "ok" end) as $status
  | (if ($usage != null and $usage.five_hour.resets_at != null) then ($usage.five_hour.resets_at | isoz)
     elif $blk != null then $blk.endTime
     else null end) as $five_reset
  | (if ($usage != null and $usage.seven_day.resets_at != null) then ($usage.seven_day.resets_at | isoz)
     else $next_monday end) as $week_reset
  | {
      updated_at: $ts,
      status: $status,
      basis: (if $usage != null then "oauth" else "cost" end),
      error: null,
      five_hour: (if ($usage != null or $blocks != null) then {
        percent: round1($five_pct),
        cost_usd: $five_cost,
        cost_cap: $five_cap,
        tokens_used: (if $blk != null then ($blk.totalTokens // 0) else null end),
        resets_at: $five_reset,
        is_active: (if $blk != null then ($blk.isActive // false) else true end),
        models: (if $blk != null then ($blk.models // []) else [] end)
      } else null end),
      weekly: (if ($usage != null or $weekly != null) then {
        percent: round1($week_pct),
        cost_usd: $week_cost,
        cost_cap: $week_cap,
        tokens_used: (if $wk != null then ($wk.totalTokens // 0) else null end),
        resets_at: $week_reset,
        week_start: (if $wk != null then ($wk.week // $wk.period) else null end)
      } else null end)
    }
' > "$TMP_FILE"

mv "$TMP_FILE" "$STATE_FILE"

# --- Stats para las pestañas Resumen / Modelos (ccusage local) ---------------
# Datos LOCALES de Claude Code de esta máquina (no la cuenta global de claude.ai).
# Se escriben aparte en stats.json para no inflar el state.json de límites.
DAILY_JSON=""
if [[ -n "$CCUSAGE" ]]; then
  DAILY_JSON="$(ccusage_json daily --json --breakdown)"
  jq -e . <<<"$DAILY_JSON" >/dev/null 2>&1 || DAILY_JSON=""
fi
if [[ -n "$DAILY_JSON" ]]; then
  # --- Fase 2: sesiones, mensajes y hora pico desde transcripts crudos --------
  # grep/awk (NO jq) porque ~/.claude/projects puede pesar cientos de MB.
  PROJ="$HOME/.claude/projects"
  SESSIONS=0; MESSAGES=0; PEAK_HOUR=-1
  if [[ -d "$PROJ" ]]; then
    SESSIONS=$(( $(find "$PROJ" -name '*.jsonl' 2>/dev/null | wc -l) ))
    MESSAGES=$(grep -rcE '"type":"(assistant|user)"' "$PROJ" --include='*.jsonl' 2>/dev/null \
               | awk -F: '{s+=$NF} END{print s+0}')
    # offset local en horas (ej -0600 -> -6); base-10 forzada para evitar octal
    Z=$(date +%z); SG=${Z:0:1}; HH=${Z:1:2}; OFF=$((10#$HH)); [[ "$SG" == "-" ]] && OFF=$((-OFF))
    PEAK_HOUR=$(grep -rhoE '"timestamp":"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}' "$PROJ" --include='*.jsonl' 2>/dev/null \
      | grep -oE 'T[0-9]{2}$' | tr -d 'T' \
      | awk -v off="$OFF" 'BEGIN{m=-1;ph=-1} {h=($1+off+24)%24; c[h]++} END{for(i=0;i<24;i++) if(c[i]>m){m=c[i];ph=i}; print ph}')
    [[ -z "$PEAK_HOUR" ]] && PEAK_HOUR=-1
  fi
  STATS_TMP="$CACHE_DIR/stats.json.tmp"
  if jq -n --argjson daily "$DAILY_JSON" --arg ts "$NOW_ISO" \
        --argjson sessions "$SESSIONS" --argjson messages "$MESSAGES" --argjson peak "$PEAK_HOUR" '
      # "tokens" mostrados = in+out (sin cache, que domina los totales crudos)
      ($daily.daily // []) as $d
      | ($d | map({
          date: .period,
          in_tok:  (.inputTokens  // 0),
          out_tok: (.outputTokens // 0),
          tokens:  ((.inputTokens // 0) + (.outputTokens // 0)),
          cost:    (.totalCost // 0),
          models:  (.modelBreakdowns // [] | map({
                      model:   .modelName,
                      tokens:  ((.inputTokens // 0) + (.outputTokens // 0))
                   }))
        })) as $days
      # agregado por modelo (suma de todos los días)
      | ([ $d[].modelBreakdowns[]? ]
          | group_by(.modelName)
          | map({
              model:   .[0].modelName,
              in_tok:  (map(.inputTokens  // 0) | add),
              out_tok: (map(.outputTokens // 0) | add),
              cost:    (map(.cost // 0) | add)
            })
          | map(. + {tot: (.in_tok + .out_tok)})
          | sort_by(-.tot)) as $models
      | (($models | map(.tot) | add) // 0) as $grand
      | {
          updated_at: $ts,
          days: $days,
          models: ($models | map(. + {
            pct: (if $grand > 0 then (.tot * 100 / $grand) else 0 end)
          })),
          summary: {
            total_tokens: $grand,
            total_cost:   (($models | map(.cost) | add) // 0),
            active_days:  ($days | map(select(.tokens > 0)) | length),
            favorite_model: ($models | (first // {}) | .model),
            sessions:  $sessions,
            messages:  $messages,
            peak_hour: $peak
          }
        }
    ' > "$STATS_TMP" 2>/dev/null; then
    mv "$STATS_TMP" "$CACHE_DIR/stats.json"
  else
    rm -f "$STATS_TMP"
  fi
fi
